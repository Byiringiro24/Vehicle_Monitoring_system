# ─── Copy this to .env on your server and fill in real values ────────────────
# This file is read by docker-compose on the server.
# NEVER commit the actual .env file — only this .env.example goes to git.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_to_a_strong_password

# ── JWT secrets (use a random 64-char string for each) ───────────────────────
JWT_SECRET=change_me_min_32_chars_random_string_here
JWT_REFRESH_SECRET=change_refresh_secret_min_32_chars_here

# ── Frontend URLs (replace with your actual server domain or IP) ─────────────
# Example with domain:  https://fleet.yourcompany.com
# Example with IP:      http://41.186.X.X:4000
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP_OR_DOMAIN:4000
NEXT_PUBLIC_WS_URL=ws://YOUR_SERVER_IP_OR_DOMAIN:4000

# ── CORS — which origins the backend will accept requests from ────────────────
# This must match the URL your browser uses to open the frontend
CORS_ORIGIN=http://YOUR_SERVER_IP_OR_DOMAIN:3000
